          "schema_version": 0,
          "attributes": {
            "content": "variant: flatcar\r\nversion: 1.0.0\r\npasswd:\r\n  users:\r\n    - name: core\r\n      ssh_authorized_keys:\r\n        - ssh-rsa  shrus@Shrush\r\n\r\nstorage:\r\n  files:\r\n    - path: /opt/k3s-install.sh\r\n      mode: 0777\r\n      contents:\r\n        source: https://get.k3s.io\r\n\r\n    # - path: /opt/install_helm.sh\r\n    #   mode: 0777\r\n    #   contents: \r\n    #     inline: |\r\n    #         export KUBECONFIG=/etc/rancher/k3s/k3s.yaml\r\n    #         wget https://get.helm.sh/helm-v3.13.1-linux-amd64.tar.gz\r\n    #         tar -zxvf helm-v3.13.1-linux-amd64.tar.gz\r\n    #         mkdir -p ~/bin\r\n    #         mv linux-amd64/helm ~/bin/helm\r\n    #         export PATH=$PATH:~/bin\r\n    #         helm version\r\n    #         helm repo add gitlab https://charts.gitlab.io --kubeconfig=/etc/rancher/k3s/k3s.yaml\r\n    #         helm repo update --kubeconfig=/etc/rancher/k3s/k3s.yaml\r\n    #         helm upgrade --kubeconfig=/etc/rancher/k3s/k3s.yaml --install demo-agent gitlab/gitlab-agent --namespace gitlab-agent-demo-agent --create-namespace --set image.tag=v16.5.0 --set config.token=glagent-shBxU2g4RnmqhvA_o3TruCTdbzPHLMcBCGQeg4hGup9xmmu1bA --set config.kasAddress=wss://kas.gitlab.com\r\n\r\n\r\n    # - path: /opt/install_gitlabagent.sh\r\n    #   mode: 0777\r\n    #   contents: \r\n    #     inline: |\r\n    #        helm upgrade --install demo-agent gitlab/gitlab-agent --namespace gitlab-agent-demo-agent --create-namespace --set image.tag=v16.5.0 --set config.token=glagent-shBxU2g4RnmqhvA_o3TruCTdbzPHLMcBCGQeg4hGup9xmmu1bA --set config.kasAddress=wss://kas.gitlab.com\r\nsystemd:\r\n  units:\r\n    - name: k3s-install.service\r\n      enabled: true\r\n      contents: |\r\n        [Unit]\r\n        Description=Run K3s script\r\n        Wants=network-online.target\r\n        After=network.target network-online.target\r\n        ConditionPathExists=/opt/k3s-install.sh\r\n        ConditionPathExists=!/opt.bin/k3s-install.sh\r\n        ConditionPathExists=!/opt/bin/k3s\r\n        [Service]\r\n        Type=forking\r\n        TimeoutStartSec=180\r\n        RemainAfterExit=yes\r\n        KillMode=process\r\n        Environment=\"K3S_TOKEN=secret_edgecluster_token\"\r\n        Environment=\"INSTALL_K3S_EXEC=server --disable=traefik --cluster-init --write-kubeconfig-mode 644\"\r\n        ExecStart=/usr/bin/sh -c \"/opt/k3s-install.sh\"\r\n        [Install]\r\n        WantedBy=multi-user.target\r\n\r\n    # - name: helm.service\r\n    #   enabled: true \r\n    #   contents: |\r\n    #     [Unit]\r\n    #     After=cinderintr.service\r\n    #     Requires=cinderintr.service\r\n    #     [Service]\r\n    #     ExecStart=/usr/bin/sh -c \"/opt/install_helm.sh\"\r\n    #     [Install]\r\n    #     WantedBy=multi-user.target\r\n    # - name: gitlabagent.service\r\n    #   enabled: true \r\n    #   contents: |\r\n    #     [Unit]\r\n    #     Wants=network-online.target\r\n    #     After=network.target network-online.target\r\n    #     [Service]\r\n    #     ExecStart=/usr/bin/sh -c \"/opt/install_gitlabagent.sh\"\r\n    #     [Install]\r\n    #     WantedBy=multi-user.target",
